{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__auth0",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-activity.sh",
            "timeout": 10,
            "statusMessage": "Logging Auth0 activity..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-activity.sh",
            "timeout": 10,
            "statusMessage": "Logging command..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__auth0",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-activity.sh",
            "timeout": 10,
            "statusMessage": "Logging failed Auth0 operation..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-stop.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-session.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
